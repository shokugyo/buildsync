generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                    String                @id @default(cuid())
  name                  String
  kanaName              String?
  type                  String                @default("元請")
  url                   String?
  postalCode            String?
  prefecture            String?
  address               String?
  address1              String?
  address2              String?
  representativeName    String?
  phone                 String?
  email                 String?
  logoPath              String?
  constructionImagePath String?
  registrationNumber    String?
  logoUrl               String?
  sealUrl               String?
  bankName              String?
  bankBranch            String?
  bankAccountType       String?
  bankAccountNumber     String?
  bankAccountName       String?
  defaultPaymentTerms   Int                   @default(30)
  plan                  String                @default("Basic")
  createdAt             DateTime              @default(now())
  users                 User[]
  projects              Project[]
  orders                Order[]
  invoices              Invoice[]
  afterServiceRecords   AfterServiceRecord[]
  departments           Department[]
  webhookConfigs        WebhookConfig[]
  apiKeys               ApiKey[]
  safetyPatrols         SafetyPatrol[]
  supplierEvaluations   SupplierEvaluation[]
  budgets               Budget[]
  workerRosters         WorkerRoster[]
  subcontractorNotices  SubcontractorNotice[]
  materials             Material[]
  materialOrders        MaterialOrder[]
  equipments            Equipment[]
  documentFolders       DocumentFolder[]
  documents             Document[]
  taxRates              TaxRate[]
  constructionLedgers   ConstructionLedger[]
  ipRestrictions        IpRestriction[]
  emailTemplates        EmailTemplate[]
  projectTemplates      ProjectTemplate[]
  workOrders            WorkOrder[]
  customerSurveys       CustomerSurvey[]
  siteDiaries           SiteDiary[]
  projectCompletions    ProjectCompletion[]
  estimateTemplates     EstimateTemplate[]
  invitations           Invitation[]
  completionDocuments   CompletionDocument[]
  workerCertifications  WorkerCertification[]
  safetyEducations      SafetyEducation[]
  materialMasters       MaterialMaster[]
  expenses              Expense[]
  costCategories        CostCategory[]
  monthlyAttendanceLocks MonthlyAttendanceLock[]
  announcements          Announcement[]         @relation("AnnouncementCompany")
  advancePayments       AdvancePayment[]
  leaveRequests         LeaveRequest[]
  shifts                Shift[]
  tasks                 Task[]
  projectRisks          ProjectRisk[]
  milestones            Milestone[]
  vehicles              Vehicle[]
  tools                 Tool[]
  departmentBudgets     DepartmentBudget[]
  insurances            Insurance[]
  inquiries             Inquiry[]
  contracts             Contract[]
  warranties            Warranty[]
  reportSchedules       ReportSchedule[]
  bids                  Bid[]
  documentHashes        DocumentHash[]
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  name                String
  role                String               @default("一般")
  status              String               @default("有効")
  companyId           String
  company             Company              @relation(fields: [companyId], references: [id])
  createdAt           DateTime             @default(now())
  jobType             String?
  department          String?
  phone               String?
  notifyEmail         String?
  avatarPath          String?
  showAvatar          Boolean              @default(false)
  googleCalendarUrl   String?
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  totpSecret          String?
  totpEnabled         Boolean              @default(false)
  totpBackupCodes     String?
  managedProjects     Project[]            @relation("Manager")
  salesProjects       Project[]            @relation("Sales")
  projectMemberships  ProjectMember[]
  schedules           Schedule[]
  photos              Photo[]
  messages            ChatMessage[]
  chatReactions       ChatReaction[]       @relation("ChatReactionUser")
  inspections         Inspection[]
  reports             DailyReport[]
  workReports         WorkReport[]
  approvedWorkReports WorkReport[]         @relation("WorkReportApprover")
  defects             Defect[]
  notifications       Notification[]
  drawings            Drawing[]
  documents           Document[]           @relation("DocumentUploader")
  drawingPins         DrawingPin[]         @relation("DrawingPinAuthor")
  drawingVersions     DrawingVersion[]     @relation("DrawingVersionUploader")
  paymentRecords      PaymentRecord[]      @relation("PaymentRecorder")
  leads               Lead[]
  nearMisses          NearMiss[]
  leadActivities      LeadActivity[]       @relation("LeadActivityUser")
  safetyPatrols       SafetyPatrol[]       @relation("SafetyPatrolUser")
  supplierEvaluations SupplierEvaluation[] @relation("SupplierEvaluator")
  preference          UserPreference?
  assignedWorkOrders  WorkOrder[]          @relation("WorkOrderAssignee")
  hourlyRate              Float                @default(2000)
  paidLeaveDays           Float                @default(10)
  siteDiaries             SiteDiary[]          @relation("SiteDiaryAuthor")
  completionDocuments     CompletionDocument[] @relation("CompletionDocUploader")
  workerCertifications    WorkerCertification[] @relation("WorkerCert")
  submittedExpenses       Expense[]            @relation("ExpenseSubmitter")
  approvedExpenses        Expense[]            @relation("ExpenseApprover")
  attendanceLocks         MonthlyAttendanceLock[] @relation("AttendanceLockUser")
  announcements           Announcement[]          @relation("AnnouncementAuthor")
  requestedAdvances       AdvancePayment[]     @relation("AdvanceRequester")
  approvedAdvances        AdvancePayment[]     @relation("AdvanceApprover")
  leaveRequests           LeaveRequest[]       @relation("LeaveRequester")
  approvedLeaves          LeaveRequest[]       @relation("LeaveApprover")
  shifts                  Shift[]              @relation("ShiftUser")
  assignedTasks           Task[]               @relation("TaskAssignee")
  createdTasks            Task[]               @relation("TaskCreator")
  drivenVehicles          Vehicle[]            @relation("VehicleDriver")
  assignedInquiries       Inquiry[]            @relation("InquiryAssignee")
  managedDepts            Department[]         @relation("DeptManager")
  orderApprovals          OrderApproval[]      @relation("OrderApprover")
  invoiceApprovals        InvoiceApproval[]    @relation("InvoiceApprover")
}

model Customer {
  id                  String               @id @default(cuid())
  name                String
  type                String               @default("個人")
  deletedAt           DateTime?
  address             String?
  phone               String?
  email               String?
  companyId           String
  createdAt           DateTime             @default(now())
  projects            Project[]
  invoices            Invoice[]
  leads               Lead[]
  afterServiceRecords AfterServiceRecord[]
  customerSurveys     CustomerSurvey[]
  inquiries           Inquiry[]
  contracts           Contract[]
  shareTokens         ProjectShareToken[]
}

model Project {
  id                   String                @id @default(cuid())
  projectNumber        String                @unique
  name                 String
  status               String                @default("引合")
  deletedAt            DateTime?
  customerId           String?
  customer             Customer?             @relation(fields: [customerId], references: [id])
  address              String?
  workType             String?
  managerId            String?
  manager              User?                 @relation("Manager", fields: [managerId], references: [id])
  salesId              String?
  sales                User?                 @relation("Sales", fields: [salesId], references: [id])
  contractAmount       Float?
  estimatedCost        Float?
  startDate            DateTime?
  endDate              DateTime?
  deliveryDate         DateTime?
  notes                String?
  cautions             String?
  siteEmergencyContact String?
  siteEmergencyPhone   String?
  lat                  Float?
  lng                  Float?
  propertyType         String?
  propertyName         String?
  propertyNameKana     String?
  ridgepoleDate        DateTime?
  labels               String?
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  schedules            Schedule[]
  photos               Photo[]
  chatRooms            ChatRoom[]
  inspections          Inspection[]
  orders               Order[]
  invoices             Invoice[]
  budgets              Budget[]
  reports              DailyReport[]
  workReports          WorkReport[]
  defects              Defect[]
  drawings             Drawing[]
  documents            Document[]
  documentFolders      DocumentFolder[]
  constructionLedgers  ConstructionLedger[]
  estimates            Estimate[]
  attendances          WorkerAttendance[]
  members              ProjectMember[]
  shareTokens          ProjectShareToken[]
  kyActivities         KyActivity[]
  nearMisses           NearMiss[]
  afterServiceRecords  AfterServiceRecord[]
  safetyPatrols        SafetyPatrol[]
  supplierEvaluations  SupplierEvaluation[]
  workerRosters        WorkerRoster[]
  subcontractorNotices SubcontractorNotice[]
  materials            Material[]
  materialOrders       MaterialOrder[]
  equipments           Equipment[]
  WorkOrder            WorkOrder[]
  customerSurveys      CustomerSurvey[]
  shifts               Shift[]
  siteDiaries          SiteDiary[]
  completion           ProjectCompletion?
  completionDocuments  CompletionDocument[]
  safetyEducations     SafetyEducation[]
  expenses             Expense[]
  advancePayments      AdvancePayment[]
  tasks                Task[]
  projectRisks         ProjectRisk[]
  milestones           Milestone[]
  vehicles             Vehicle[]
  tools                Tool[]
  insurances           Insurance[]
  inquiries            Inquiry[]
  contracts            Contract[]
  warranties           Warranty[]
  bids                 Bid[]
}

model Schedule {
  id           String               @id @default(cuid())
  projectId    String
  project      Project              @relation(fields: [projectId], references: [id])
  name         String
  startDate    DateTime
  endDate      DateTime
  actualStart  DateTime?
  actualEnd    DateTime?
  assigneeId   String?
  assignee     User?                @relation(fields: [assigneeId], references: [id])
  progress     Int                  @default(0)
  status       String               @default("未着手")
  category     String?
  notes        String?
  createdAt    DateTime             @default(now())
  dependencies ScheduleDependency[] @relation("DependentSchedule")
  successors   ScheduleDependency[] @relation("PredecessorSchedule")
}

model ScheduleDependency {
  id            String   @id @default(cuid())
  scheduleId    String
  schedule      Schedule @relation("DependentSchedule", fields: [scheduleId], references: [id], onDelete: Cascade)
  predecessorId String
  predecessor   Schedule @relation("PredecessorSchedule", fields: [predecessorId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, predecessorId])
}

model SafetyPatrol {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id])
  patrolDate         DateTime
  patrolledBy        String
  patroller          User     @relation("SafetyPatrolUser", fields: [patrolledBy], references: [id])
  checkItems         String // JSON: [{item: string, result: "良好"|"要改善"|"不適合", comment: string}]
  overallResult      String   @default("良好")
  correctionRequired Boolean  @default(false)
  notes              String?
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id])
  createdAt          DateTime @default(now())
}

model Photo {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  uploaderId     String
  uploader       User     @relation(fields: [uploaderId], references: [id])
  filePath       String
  comment        String?
  tags           String?
  location       String?
  shootingType   String?
  blackboardData String?
  latitude       Float?
  longitude      Float?
  is360          Boolean  @default(false)
  category       String   @default("一般")
  createdAt      DateTime @default(now())
}

model ChatRoom {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  name      String
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id             String            @id @default(cuid())
  roomId         String
  room           ChatRoom          @relation(fields: [roomId], references: [id])
  senderId       String
  sender         User              @relation(fields: [senderId], references: [id])
  content        String
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  parentId       String?
  createdAt      DateTime          @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  readBy         ChatMessageRead[]
  reactions      ChatReaction[]
}

model ChatReaction {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("ChatReactionUser", fields: [userId], references: [id])
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
}

model ChatMessageRead {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime    @default(now())

  @@unique([messageId, userId])
}

model Inspection {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id])
  name            String
  type            String
  scheduledDate   DateTime?
  actualDate      DateTime?
  inspectorId     String?
  inspector       User?            @relation(fields: [inspectorId], references: [id])
  status          String           @default("未実施")
  notes           String?
  approvalStatus  String?
  inspectionGroup String?
  sentAt          DateTime?
  hasCorrection   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  items           InspectionItem[]
  defects         Defect[]
}

model InspectionItem {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  name         String
  result       String?
  comment      String?
  photoUrl     String?
}

model Defect {
  id             String      @id @default(cuid())
  inspectionId   String?
  inspection     Inspection? @relation(fields: [inspectionId], references: [id])
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id])
  content        String
  location       String?
  assigneeId     String?
  assignee       User?       @relation(fields: [assigneeId], references: [id])
  dueDate        DateTime?
  status         String      @default("未対応")
  photoIds       String? // comma-separated photo IDs
  beforePhotoIds String? // comma-separated photo IDs (是正前)
  afterPhotoIds  String? // comma-separated photo IDs (是正後)
  createdAt      DateTime    @default(now())
}

model Supplier {
  id                String               @id @default(cuid())
  name              String
  type              String               @default("協力会社")
  deletedAt         DateTime?
  address           String?
  phone             String?
  email             String?
  contact           String?
  notes             String?
  licenseNumber     String?
  licenseType       String?
  licenseExpiry     DateTime?
  insuranceExpiry   DateTime?
  bankName          String?
  bankBranch        String?
  bankAccountNumber String?
  bankAccountName   String?
  companyId         String
  createdAt         DateTime             @default(now())
  orders          Order[]
  evaluations     SupplierEvaluation[]
  materials       Material[]
  materialMasters MaterialMaster[]
}

model Material {
  id          String    @id @default(cuid())
  name        String
  unit        String
  quantity    Float
  unitPrice   Float?
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  scheduledAt DateTime?
  deliveredAt DateTime?
  status      String    @default("未発注")
  notes       String?
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
}

model Equipment {
  id               String    @id @default(cuid())
  name             String
  type             String
  serialNumber     String?
  status           String    @default("利用可能")
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id])
  assignedFrom     DateTime?
  assignedTo       DateTime?
  lastInspectedAt  DateTime?
  nextInspectionAt DateTime?
  notes            String?
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  createdAt        DateTime  @default(now())
}

model SupplierEvaluation {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  qualityScore  Int
  costScore     Int
  scheduleScore Int
  safetyScore   Int
  overallScore  Float
  comment       String?
  evaluatedBy   String
  evaluator     User     @relation("SupplierEvaluator", fields: [evaluatedBy], references: [id])
  evaluatedAt   DateTime
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model Order {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id])
  supplierId       String?
  supplier         Supplier?       @relation(fields: [supplierId], references: [id])
  orderNumber      String          @unique
  subject          String
  workType         String?
  orderDate        DateTime?
  deliveryDate     DateTime?
  paymentTerms     String?
  amount           Float
  taxAmount        Float
  totalAmount      Float
  status           String          @default("下書き")
  notes            String?
  confirmedAt      DateTime?
  confirmedBy      String?
  confirmationNote String?
  deliveredAt      DateTime?
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  createdAt        DateTime        @default(now())
  items            OrderItem[]
  approvals        OrderApproval[]
}

model OrderApproval {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation("OrderApprover", fields: [approverId], references: [id])
  level      Int      @default(1)
  action     String
  comment    String?
  createdAt  DateTime @default(now())
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float  @default(1)
  unitPrice Float  @default(0)
  amount    Float  @default(0)
  sortOrder Int    @default(0)
}

model Invoice {
  id            String            @id @default(cuid())
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id])
  customerId    String?
  customer      Customer?         @relation(fields: [customerId], references: [id])
  invoiceNumber String            @unique
  invoiceDate   DateTime?
  dueDate       DateTime?
  amount        Float
  taxAmount     Float
  totalAmount   Float
  status        String            @default("未作成")
  paidDate       DateTime?
  notes          String?
  rejectReason   String?
  reminderSentAt DateTime?
  reminderCount  Int               @default(0)
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  createdAt      DateTime          @default(now())
  items          InvoiceItem[]
  payments       PaymentRecord[]
  approvals      InvoiceApproval[]
}

model InvoiceApproval {
  id         String   @id @default(cuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation("InvoiceApprover", fields: [approverId], references: [id])
  level      Int      @default(1)
  action     String   // '承認' | '差し戻し'
  comment    String?
  createdAt  DateTime @default(now())
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float   @default(1)
  unitPrice Float   @default(0)
  amount    Float   @default(0)
  sortOrder Int     @default(0)
  taxRate   Float   @default(10)
}

model Budget {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category       String
  description    String?
  amount         Float
  orderedAmount  Float    @default(0)
  invoicedAmount Float    @default(0)
  paidAmount     Float    @default(0)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DailyReport {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id])
  workDate   DateTime
  weather    String?
  content    String
  workers    Int?
  progress   String?
  issues     String?
  nextPlan   String?
  createdAt  DateTime @default(now())
}

model Drawing {
  id            String           @id @default(cuid())
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id])
  uploaderId    String
  uploader      User             @relation(fields: [uploaderId], references: [id])
  name          String
  drawingType   String           @default("その他")
  drawingNumber String?
  version       Int              @default(1)
  isLatest      Boolean          @default(true)
  filePath      String
  description   String?
  sharedWith    String?          // JSON array of userId strings; null means public to all
  createdAt     DateTime         @default(now())
  pins          DrawingPin[]
  versions      DrawingVersion[]
}

model DrawingVersion {
  id         String   @id @default(cuid())
  drawingId  String
  drawing    Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  version    Int
  fileUrl    String
  fileName   String
  uploadedBy String
  uploader   User     @relation("DrawingVersionUploader", fields: [uploadedBy], references: [id])
  notes      String?
  createdAt  DateTime @default(now())
}

model PaymentRecord {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Float
  paidAt        DateTime
  paymentMethod String?
  notes         String?
  recordedBy    String
  recorder      User     @relation("PaymentRecorder", fields: [recordedBy], references: [id])
  createdAt     DateTime @default(now())
}

model DrawingPin {
  id         String    @id @default(cuid())
  drawingId  String
  drawing    Drawing   @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  x          Float // percentage 0-100 of image width
  y          Float // percentage 0-100 of image height
  comment    String
  authorId   String
  author     User      @relation("DrawingPinAuthor", fields: [authorId], references: [id])
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderHierarchy")
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id])
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  createdAt DateTime         @default(now())
  documents Document[]
}

model Document {
  id         String          @id @default(cuid())
  name       String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  folderId   String?
  folder     DocumentFolder? @relation(fields: [folderId], references: [id])
  projectId  String?
  project    Project?        @relation(fields: [projectId], references: [id])
  uploadedBy String
  uploader   User            @relation("DocumentUploader", fields: [uploadedBy], references: [id])
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id])
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?
}

model Estimate {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id])
  estimateNumber  String         @unique
  estimateDate    DateTime?
  validUntil      DateTime?
  amount          Float
  taxAmount       Float          @default(0)
  totalAmount     Float
  status          String         @default("作成中")
  notes           String?
  companyId       String
  createdAt       DateTime       @default(now())
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  items           EstimateItem[]
}

model EstimateItem {
  id         String   @id @default(cuid())
  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  quantity   Float    @default(1)
  unitPrice  Float    @default(0)
  amount     Float    @default(0)
  sortOrder  Int      @default(0)
}

model ProjectMember {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  memberRole String   @default("一般")
  labels     String?
  createdAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model MasterItem {
  id        String   @id @default(cuid())
  type      String
  value     String
  label     String
  sortOrder Int      @default(0)
  companyId String
  createdAt DateTime @default(now())
}

model InspectionTemplate {
  id        String   @id @default(cuid())
  name      String
