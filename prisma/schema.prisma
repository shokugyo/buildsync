  project        Project?  @relation(fields: [projectId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  contractNumber String
  title          String
  contractType   String
  amount         Float?
  startDate      DateTime?
  endDate        DateTime?
  signedAt       DateTime?
  fileUrl        String?
  fileName       String?
  status         String    @default("作成中")
  notes          String?
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  createdAt      DateTime  @default(now())
}

model Warranty {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  title      String
  category   String
  startDate  DateTime
  endDate    DateTime
  contractor String?
  notes      String?
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
}

model MaterialOrder {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  quantity    Float
  unit        String    @default("個")
  unitPrice   Float?
  totalAmount Float?
  orderedAt   DateTime?
  deliveredAt DateTime?
  supplier    String?
  status      String    @default("未発注")
  notes       String?
  companyId   String
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])
}

model ReportSchedule {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  reportType  String
  frequency   String
  dayOfWeek   Int?
  dayOfMonth  Int?
  recipients  String
  enabled     Boolean   @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime  @default(now())
  company     Company   @relation(fields: [companyId], references: [id])
}

model DocumentHash {
  id           String   @id @default(cuid())
  documentType String   // 'invoice' | 'order' | 'contract' | 'estimate'
  documentId   String
  hash         String   // SHA-256 hex
  algorithm    String   @default("SHA-256")
  createdAt    DateTime @default(now())
  createdBy    String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])

  @@unique([documentType, documentId])
  @@index([companyId])
}

model Bid {
  id                 String    @id @default(cuid())
  projectId          String?
  title              String
  bidDate            DateTime
  submissionDeadline DateTime?
  estimatedAmount    Float?
  bidAmount          Float?
  status             String    @default("準備中")
  result             String?
  competitors        Int       @default(0)
  notes              String?
  companyId          String
  createdAt          DateTime  @default(now())
  project            Project?  @relation(fields: [projectId], references: [id])
  company            Company   @relation(fields: [companyId], references: [id])
}
